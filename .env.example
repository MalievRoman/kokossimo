FRONTEND_URL=http://localhost:5173
VITE_BACKEND_URL=http://127.0.0.1:8000
VITE_API_URL=http://127.0.0.1:8000/api

DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL (магазин + применения сертификатов). Без этих переменных — SQLite локально.
# POSTGRES_DB=kokossimo
# POSTGRES_USER=...
# POSTGRES_PASSWORD=...
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# Отдельная БД для таблиц certificates / certificate_transactions (если не задана — та же, что POSTGRES_DB)
# CERTIFICATES_POSTGRES_DB=kokossimo_certificates

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
MOYSKLAD_SITE_SYNC_ENABLED=false
OPENAI_CATEGORIZE_ENABLED=false
YOOKASSA_RETURN_URL=http://localhost:5173/checkout/success
